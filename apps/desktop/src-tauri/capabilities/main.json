{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Allowlist for the main Buddysaradhi window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-read-dir",
    "shell:allow-open",
    "dialog:allow-save",
    "updater:allow-check",
    "updater:allow-download",
    "store:allow-get",
    "store:allow-set"
  ]
}
