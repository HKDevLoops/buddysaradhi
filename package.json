{
  "name": "buddysaradhi",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/services/*",
    "apps/gateway",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@prisma/client",
      "argon2"
    ]
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && pnpm --filter web build",
    "lint": "pnpm --filter '*' lint",
    "test:unit": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:a11y": "pnpm --filter web test:a11y",
    "version:check": "node scripts/version-check.js"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod-prisma-types": "^3.3.11"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.45.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  }
}